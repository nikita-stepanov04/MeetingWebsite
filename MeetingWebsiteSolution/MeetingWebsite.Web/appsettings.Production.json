{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "ConnectionStrings": {
        "DbConnection": "Server=${DB_HOST};Initial Catalog=${DB_NAME};User ID=${DB_USER};Password=${DB_PASSWORD};TrustServerCertificate=True;Connection Timeout=60;",
        "RedisConnection": "${REDIS_HOST}:6379"
    },
    "JwtSecret": "${JWT_SECRET}"
}
